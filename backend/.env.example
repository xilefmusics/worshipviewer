# Worship Viewer backend ‚Äî copy to `.env` or export before `cargo run`.
# Names match the `Settings` struct in `src/settings.rs` (loaded via `envy`).

# --- HTTP ---
HOST=127.0.0.1
PORT=8080

# --- Session cookie ---
POST_LOGIN_PATH=/
COOKIE_NAME=sso_session
COOKIE_SECURE=false
SESSION_TTL_SECONDS=31536000

# --- OTP email ---
OTP_TTL_SECONDS=300
OTP_PEPPER=changeme
OTP_MAX_ATTEMPTS=5
# OTP_ALLOW_SELF_SIGNUP=true
# WORSHIP_OTP_ALLOW_SELF_SIGNUP=true

# --- Gmail SMTP (required to send OTP mail) ---
GMAIL_APP_PASSWORD=
GMAIL_FROM=

# --- OIDC (Google) ---
OIDC_ISSUER_URL=https://accounts.google.com
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_REDIRECT_URL=http://localhost:8080/auth/callback
# OIDC_SCOPES=openid,profile,email

# --- Database ---
DB_ADDRESS=mem://
DB_NAMESPACE=main
DB_DATABASE=main
# DB_USERNAME=app
# DB_PASSWORD=app
DB_MIGRATION_PATH=db-migrations

# --- Static assets & uploads ---
STATIC_DIR=static
BLOB_DIR=blobs
BLOB_UPLOAD_MAX_BYTES=20971520
# AVATAR_UPLOAD_MAX_BYTES=2097152

# --- Rate limits (per client IP) ---
AUTH_RATE_LIMIT_RPS=1
AUTH_RATE_LIMIT_BURST=5
API_RATE_LIMIT_RPS=50
API_RATE_LIMIT_BURST=200

# --- Local dev helpers (never enable in production) ---
# INITIAL_ADMIN_USER_EMAIL=admin@example.com
# INITIAL_ADMIN_USER_TEST_SESSION=true

# --- Production / logging ---
# WORSHIP_PRODUCTION=true
# RUST_ENV=production
# RUST_LOG=info
# LOG_FORMAT=json

# --- OpenAPI metadata (optional) ---
# OPENAPI_CONTACT_EMAIL=
# OPENAPI_IMPRINT_URL=

# --- Build metadata (CI / Docker sets this for GET /api/v1/about) ---
# GIT_COMMIT_SHA=
